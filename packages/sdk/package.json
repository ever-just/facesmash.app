{
  "name": "@facesmash/sdk",
  "version": "3.0.0",
  "description": "Passwordless facial recognition authentication SDK. Drop-in face login for any website.",
  "author": "EVERJUST COMPANY",
  "license": "MIT",
  "homepage": "https://facesmash.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/ever-just/facesmash.app",
    "directory": "packages/sdk"
  },
  "keywords": [
    "facesmash",
    "face-recognition",
    "authentication",
    "passwordless",
    "biometric",
    "face-login",
    "face-api",
    "tensorflow",
    "react"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.15"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.4.0",
    "typescript": "^5.6.0"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
